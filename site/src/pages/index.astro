    <style>
    * {
      margin: 0;
      padding: 0;
    }

    html {
      background-color: black;
    }

    body {
      display: flex;
      min-height: 100vh;
      justify-content: center;
      align-items: center;
      padding: 1rem;
      box-sizing: border-box;
    }

    h1, p, li {
      color: white;
      font-family: 'Terminus (TTF)';
      font-weight: 100;
    }

    ul {
      padding-top: 1rem;
      margin-left: 1rem;
    }

    h1 {
      font-size: 1.5em;
    }

    p {
      font-size: 1em;
    }

    #root {
      display: flex;
      gap: 2rem;
      max-width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }

    #left-div {
      text-align: center;
    }

    #right-div {
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 16rem;
    }

    #pfp-img {
      height: 10rem;
      max-width: 100%;
      object-fit: cover;
    }

    #icons {
      display: flex;
      gap: 0.5rem;
      justify-content: space-around;
    }

    #icon {
      width: 1.5rem;
      height: 1.5rem;
    }

    /* Mobile styles */
    @media (max-width: 640px) {
      #root {
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      #pfp-img {
        height: 8rem;
      }

      h1 {
        font-size: 1.25em;
      }

      #right-div {
      }

      ul {
        text-align: left;
      }
    }
    </style>
