---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    description?: string;
    fromdate?: string;
    todate?: string;
    category?: string;
    hidden?: boolean;
  };
}

const { title, subtitle, description, fromdate, todate, category, hidden } = Astro.props.frontmatter;
---
<BaseLayout pageTitle={title}>
  <slot/>
</BaseLayout>
