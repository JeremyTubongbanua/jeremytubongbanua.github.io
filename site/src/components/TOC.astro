---
// github.com/rezahedi/rezahedi.dev/blob/main/src/components/TOC.astro

const { headings } = Astro.props;

// code from https://medium.com/@rezahedi/how-to-build-table-of-contents-in-astro-and-sectionize-the-markdown-content-78bee84e6a7f
const buildHierarchy = (headings: {slug: string; text: string; depth: number;}[]) => {
  let toc: any[] = [];
  let parentHeadings: any = {};

  if (!headings) {
    return toc;
  }

  headings.forEach((h) => {
    const heading = { ...h, subheadings: [] };
    parentHeadings[heading.depth] = heading;

    // Change 2 to 1 if your markdown includes <h1>
    if(heading.depth == 2) {
      toc.push(heading);
    } else {
      if(parentHeadings[heading.depth - 1]) {
        parentHeadings[heading.depth - 1].subheadings = parentHeadings[heading.depth - 1].subheadings || [];
      }
    }
  });

  return toc;
};

const toc = buildHierarchy(headings);

---
{toc && toc.length > 0 && (
  <nav class="article-toc">
    <ul>
      {toc.map((heading) => (
        <li>
          <a href={'#' + heading.slug}>
            {heading.text}
          </a>
          {heading.subheadings.length > 0 && (
            <ul>
              {heading.subheadings.map((subheading: any) => (
                <Astro.self heading={subheading} />
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>
)}
